OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
CLARA_LLM_PROVIDER=openai_responses
CLARA_LLM_BASE_URL=https://api.openai.com/v1
CLARA_LLM_API_KEY=
CLARA_LLM_MODEL=gpt-4o-mini

# GPTsAPI example:
# CLARA_LLM_PROVIDER=gptsapi
# CLARA_LLM_BASE_URL=https://api.gptsapi.net/v1
# CLARA_LLM_API_KEY=your_gptsapi_key
# CLARA_LLM_MODEL=gpt-4o-mini

# DeepSeek V4 example:
# CLARA_LLM_PROVIDER=deepseek
# CLARA_LLM_BASE_URL=https://api.deepseek.com
# CLARA_LLM_API_KEY=your_deepseek_key
# CLARA_LLM_MODEL=deepseek-v4-flash
# Alternative model: deepseek-v4-pro

# Comma-separated frontend origins allowed by FastAPI CORS.
CLARA_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,null
